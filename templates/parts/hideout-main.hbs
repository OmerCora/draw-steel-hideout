{{!-- Hideout Main Panel: tab switcher + Projects/Stash content --}}
<div class="dshideout-main">

  {{!-- Tab buttons --}}
  <nav class="dshideout-tabs">
    <button class="dshideout-tab-btn {{#dshideout-eq activeTab 'projects'}}active{{/dshideout-eq}}"
            data-action="switchTab" data-tab="projects">
      <i class="fas fa-scroll"></i> {{localize "DSHIDEOUT.Tab.Projects"}}
    </button>
    <button class="dshideout-tab-btn {{#dshideout-eq activeTab 'archives'}}active{{/dshideout-eq}}"
            data-action="switchTab" data-tab="archives">
      <i class="fas fa-book-open"></i> {{localize "DSHIDEOUT.Tab.Archives"}}
    </button>
    <button class="dshideout-tab-btn {{#dshideout-eq activeTab 'stash'}}active{{/dshideout-eq}}"
            data-action="switchTab" data-tab="stash">
      <i class="fas fa-box-open"></i> {{localize "DSHIDEOUT.Tab.Stash"}}
    </button>
  </nav>

  {{!-- ==================  PROJECTS TAB  ================== --}}
  {{#dshideout-eq activeTab "projects"}}
  <div class="dshideout-projects-panel" data-projects-drop-zone>

    {{!-- Filter / Sort row --}}
    <div class="dshideout-projects-controls">
      <select name="projectFilter" class="dshideout-select">
        <option value="all" {{#dshideout-eq projectFilter 'all'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.FilterAll"}}</option>
        <option value="ongoing" {{#dshideout-eq projectFilter 'ongoing'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.FilterOngoing"}}</option>
        <option value="completed" {{#dshideout-eq projectFilter 'completed'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.FilterCompleted"}}</option>
      </select>
      <select name="projectSort" class="dshideout-select">
        <option value="progress" {{#dshideout-eq projectSort 'progress'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.SortProgress"}}</option>
        <option value="name" {{#dshideout-eq projectSort 'name'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.SortName"}}</option>
        <option value="contributors" {{#dshideout-eq projectSort 'contributors'}}selected{{/dshideout-eq}}>{{localize "DSHIDEOUT.Projects.SortContributors"}}</option>
      </select>
    </div>

    <hr class="dshideout-divider" />
    {{!-- Projects list --}}
    <ul class="dshideout-projects-list">
      {{#if projects.length}}
        {{#each projects}}
          <li class="dshideout-project-row {{#if this.completed}}is-completed{{/if}} {{#if this.hasEvent}}has-event{{/if}}"
              data-project-id="{{this.id}}">

            {{!-- ── Top bar: icon · name · actions · chevron ── --}}
            <div class="dshideout-project-topbar"
                 data-action="toggleDescription"
                 data-description-id="{{this.id}}">
              {{!-- Icon with overlaid book button (GM only) --}}
              <div class="dshideout-project-icon-wrap">
                <img class="dshideout-project-icon" src="{{this.img}}" alt="{{this.name}}" />
                {{#if @root.isGM}}
                <button type="button" class="dshideout-open-sheet-btn"
                        data-action="openProjectSheet" data-uuid="{{this.uuid}}"
                        title="{{localize 'DSHIDEOUT.Projects.OpenSheet'}}">
                  <i class="fas fa-book"></i>
                </button>
                {{/if}}
              </div>
              <span class="dshideout-project-name">
                {{this.displayName}}
                {{#if this.completed}}<span class="dshideout-completed-badge">({{localize "DSHIDEOUT.Projects.CompletedBadge"}})</span>{{/if}}
              </span>
              {{#if this.hasEvent}}
                <i class="fas fa-exclamation-circle dshideout-event-icon" title="{{localize 'DSHIDEOUT.Projects.HasEvent'}}"></i>
              {{/if}}
              {{!-- Yield / Restart buttons inline in topbar --}}
              {{#if this.canObtainYield}}
                <button type="button" class="dshideout-btn dshideout-btn-primary dshideout-topbar-action"
                        data-action="obtainYield" data-project-id="{{this.id}}">
                  <i class="fas fa-gift"></i> {{localize "DSHIDEOUT.Projects.ObtainYield"}}
                  {{#if this.yieldDisplay}} ({{this.yieldDisplay}}){{/if}}
                </button>
              {{/if}}
              {{#if this.canRestart}}
                <button type="button" class="dshideout-btn dshideout-btn-secondary dshideout-topbar-action"
                        data-action="restartProject" data-project-id="{{this.id}}">
                  <i class="fas fa-redo"></i> {{localize "DSHIDEOUT.Projects.RestartProject"}}
                </button>
              {{/if}}
              {{!-- Trash + chevron always on far right --}}
              <div class="dshideout-project-topbar-right">
                {{#if @root.isGM}}
                  {{#unless this.completed}}
                    <button type="button" class="dshideout-project-remove-btn"
                            data-action="openProjectSettings" data-project-id="{{this.id}}"
                            title="{{localize 'DSHIDEOUT.Projects.SettingsTitle'}}">
                      <i class="fas fa-cog"></i>
                    </button>
                  {{/unless}}
                  <button type="button" class="dshideout-project-remove-btn"
                          data-action="removeProject" data-project-id="{{this.id}}"
                          title="{{localize 'DSHIDEOUT.Projects.Remove'}}">
                    <i class="fas fa-trash"></i>
                  </button>
                {{/if}}
                <i class="fas fa-chevron-down dshideout-expand-icon"
                   data-action="toggleDescription"
                   data-description-id="{{this.id}}"
                   data-chevron-id="{{this.id}}"></i>
              </div>
            </div>

            {{!-- ── Body: left (meta + progress) | right (contributors) ── --}}
            <div class="dshideout-project-body"
                 data-action="toggleDescription"
                 data-description-id="{{this.id}}">
              {{!-- Left: type/chars meta + GM points editor + progress bar --}}
              <div class="dshideout-project-left">
                <div class="dshideout-project-meta">
                  <div class="dshideout-project-meta-row">
                    <span class="dshideout-meta-label">{{localize "DSHIDEOUT.Projects.TypeLabel"}}:</span>
                    <span class="dshideout-type-label">{{this.projectTypeLabel}}</span>
                  </div>
                  {{#if this.charLabels.length}}
                    <div class="dshideout-project-meta-row" style="margin-top:4px;">
                      <span class="dshideout-meta-label">{{localize "DSHIDEOUT.Projects.CharsLabel"}}:</span>
                      {{#each this.charLabels}}
                        <span class="dshideout-char-pill">{{this}}</span>
                      {{/each}}
                    </div>
                  {{/if}}
                  {{#if this.yieldText}}
                    <div class="dshideout-project-meta-row" style="margin-top:4px; margin-bottom:4px">
                      <span class="dshideout-meta-label">{{localize "DSHIDEOUT.Projects.YieldAmountLabel"}}:</span>
                      <span class="dshideout-type-label">{{this.yieldText}}</span>
                    </div>
                  {{/if}}
                </div>
                {{#if @root.isGM}}
                  <div class="dshideout-points-edit">
                    <span class="dshideout-points-edit-label">Points:</span>
                    <input type="number" class="dshideout-points-input"
                           data-project-id="{{this.id}}"
                           value="{{this.points}}"
                           min="0"
                           {{#if this.goal}}max="{{this.goal}}"{{/if}} />
                    <span class="dshideout-points-of">/</span>
                    <span class="dshideout-points-edit-label">Goal:</span>
                    <input type="number" class="dshideout-goal-input"
                           data-project-id="{{this.id}}"
                           value="{{this.goal}}"
                           min="0"
                           placeholder="—" />
                  </div>
                {{/if}}
                <div class="dshideout-progress-bar-container">
                  <div class="dshideout-progress-bar{{#unless this.hasGoal}} dshideout-bar-no-goal{{/unless}}" style="width: {{this.startPct}}%"{{#if this.animateBar}} data-animate-to="{{this.progressPct}}"{{/if}}></div>
                  <span class="dshideout-progress-label">{{this.progressLabel}}</span>
                </div>
              </div>

              {{!-- Right: contributors (rectangular grid) --}}
              <div class="dshideout-project-right">
                <span class="dshideout-contributors-label">{{localize "DSHIDEOUT.Projects.ContributorsLabel"}}</span>
                <div class="dshideout-contributors" data-project-drop-zone="{{this.id}}">
                  {{#if this.contributors.length}}
                    {{#each this.contributors}}
                      <span class="dshideout-contributor-pill{{#if this.hasRolledIndividually}} dshideout-pill-rolled{{/if}}"
                            data-actor-id="{{this.id}}"
                            title="{{this.name}}"
                            draggable="true"
                            {{#if this.isItemFollower}}data-drag-item-contributor{{else}}data-drag-contributor{{/if}}>
                        {{#if ../individualRollsEnabled}}
                          {{#if this.hasRolledIndividually}}
                            <button type="button" class="dshideout-individual-rolled"
                                    data-action="clearIndividualRoll"
                                    data-actor-id="{{this.id}}"
                                    data-project-id="{{../id}}"
                                    title="{{localize 'DSHIDEOUT.IndividualRoll.ClearRoll'}}">
                              <i class="fas fa-check"></i>
                            </button>
                          {{else if this.canRollIndividually}}
                            <button type="button" class="dshideout-individual-roll-btn"
                                    data-action="individualProjectRoll"
                                    data-actor-id="{{this.id}}"
                                    data-project-id="{{../id}}"
                                    title="{{localize 'DSHIDEOUT.IndividualRoll.Tooltip'}}">
                              <i class="fas fa-dice-d20"></i>
                            </button>
                          {{/if}}
                        {{/if}}
                        <button type="button" class="dshideout-remove-contributor"
                                data-action="removeContributor" data-actor-id="{{this.id}}"
                                title="{{localize 'DSHIDEOUT.Projects.RemoveContributor'}}">
                          <i class="fas fa-times"></i>
                        </button>
                        <img src="{{this.img}}" alt="{{this.name}}" class="dshideout-contributor-portrait" />
                        <span class="dshideout-contributor-name">{{this.name}}</span>
                      </span>
                    {{/each}}
                  {{else}}
                    <span class="dshideout-contributors-hint">
                      {{localize "DSHIDEOUT.Projects.DragContributor"}}
                    </span>
                  {{/if}}
                </div>
              </div>
            </div>

            {{!-- ── Collapsible: description ── --}}
            <div class="dshideout-collapsible {{#if this.isExpanded}}is-expanded{{/if}}"
                 data-collapsible-id="{{this.id}}"
                 data-action="toggleDescription"
                 data-description-id="{{this.id}}">
              <div class="dshideout-collapsible-inner dshideout-project-description">
                {{#if this.keywords.length}}
                  <div class="dshideout-item-keywords-row">
                    {{#each this.keywords}}<span class="dshideout-char-pill">{{this}}</span>{{/each}}
                  </div>
                {{/if}}
                {{#if this.projectSource}}
                  <p class="dshideout-project-source-field">
                    <strong>{{localize "DSHIDEOUT.Projects.ProjectSource"}}:</strong> {{this.projectSource}}
                  </p>
                {{/if}}
                {{#if this.prerequisites}}
                  <p class="dshideout-prerequisites">
                    <strong>{{localize "DSHIDEOUT.Projects.Prerequisites"}}:</strong> {{this.prerequisites}}
                  </p>
                {{/if}}
                {{{this.description}}}
              </div>
            </div>

          </li>
        {{/each}}
      {{else}}
        <li class="dshideout-empty-li">
          <div class="dshideout-empty-state">
            <i class="fas fa-scroll dshideout-empty-icon"></i>
            <p>{{localize "DSHIDEOUT.Projects.None"}}</p>
          </div>
        </li>
      {{/if}}

      {{!-- Drop zone hint (GM only — players cannot create projects) --}}
      {{#if isGM}}
        <li class="dshideout-drop-hint-li">
          <div class="dshideout-drop-hint">
            <i class="fas fa-plus-circle"></i> {{localize "DSHIDEOUT.Projects.DropHint"}}
          </div>
        </li>
      {{/if}}
    </ul>

  </div>
  {{/dshideout-eq}}

  {{!-- ==================  ARCHIVES TAB  ================== --}}
  {{#dshideout-eq activeTab "archives"}}
  <div class="dshideout-archives-panel {{#if isGM}}is-gm{{else}}is-player{{/if}}"
       {{#if isGM}}data-archives-drop-zone{{/if}}
       style="--dshideout-archive-prereq-w: {{archivePrereqWidth}}px;">
    <hr class="dshideout-divider" />
    <div class="dshideout-archives-list">
      {{#if archiveGroups.length}}
        {{#each archiveGroups}}
          <section class="dshideout-stash-group">
            <div class="dshideout-stash-group-header dshideout-archive-group-header">
              <span class="dshideout-group-icon-spacer"></span>
              <span class="dshideout-group-label">{{this.label}}</span>
              <span class="dshideout-col-header-text dshideout-archive-col-echelon">{{localize "DSHIDEOUT.Column.Echelon"}}</span>
              <span class="dshideout-col-header-text dshideout-archive-col-source">{{localize "DSHIDEOUT.Column.Source"}}</span>
              <span class="dshideout-col-header-text">{{localize "DSHIDEOUT.Column.Prerequisite"}}</span>
            </div>
            <ul class="dshideout-stash-items">
              {{#each this.items}}
                <li class="dshideout-stash-row {{#if this.isExpanded}}is-expanded{{/if}}"
                    data-archive-item-id="{{this.id}}">
                  <div class="dshideout-stash-row-header"
                       data-action="toggleDescription"
                       data-description-id="{{this.id}}">
                    <img class="dshideout-stash-icon" src="{{this.img}}" alt="{{this.name}}" />
                    <div class="dshideout-stash-info">
                      <span class="dshideout-stash-name">{{this.name}}</span>
                    </div>
                    <span class="dshideout-archive-col-echelon dshideout-col-value">{{this.echelonLabel}}</span>
                    <span class="dshideout-archive-col-source dshideout-col-value" title="{{this.projectData.source}}">{{#if this.sourceLanguage}}{{this.sourceLanguage}}{{else}}—{{/if}}</span>
                    {{#if this.hasCraftingData}}
                      <div class="dshideout-archive-prereq-ctrl">
                        {{#if this.projectData.prerequisites}}
                          <span class="dshideout-prereq-text">{{this.projectData.prerequisites}}</span>
                        {{/if}}
                        <span class="dshideout-prereq-xn">×{{this.craftCount}}</span>
                      </div>
                    {{else}}
                      <span class="dshideout-col-value dshideout-col-empty">—</span>
                    {{/if}}
                    <div class="dshideout-archive-controls">
                      {{#if this.hasCraftingData}}
                        {{#if @root.isGM}}
                          <button type="button" class="dshideout-qty-btn" data-action="decreaseCraftCount"
                                  data-archive-item-id="{{this.id}}"
                                  title="{{localize 'DSHIDEOUT.Archives.DecreaseCraftCount'}}">−</button>
                          <button type="button" class="dshideout-qty-btn" data-action="increaseCraftCount"
                                  data-archive-item-id="{{this.id}}"
                                  title="{{localize 'DSHIDEOUT.Archives.IncreaseCraftCount'}}">+</button>
                        {{/if}}
                        <button type="button" class="dshideout-btn dshideout-btn-secondary dshideout-btn-icon dshideout-archive-craft-btn"
                                data-action="beginCraftingFromArchive" data-archive-item-id="{{this.id}}"
                                title="{{#if this.craftCount}}{{localize 'DSHIDEOUT.Archives.BeginCrafting'}}{{else}}{{localize 'DSHIDEOUT.Archives.NotEnoughMaterial'}}{{/if}}"
                                {{#unless this.craftCount}}disabled{{/unless}}>
                          <i class="fas fa-hammer"></i>
                        </button>
                      {{/if}}
                      {{#if @root.isGM}}
                        <button type="button" class="dshideout-btn dshideout-btn-secondary dshideout-btn-icon"
                                data-action="openProjectSheet" data-uuid="{{this.uuid}}"
                                title="{{localize 'DSHIDEOUT.Common.OpenItemSheet'}}">
                          <i class="fas fa-book"></i>
                        </button>
                        <button type="button" class="dshideout-btn dshideout-btn-danger dshideout-btn-icon"
                                data-action="removeArchiveEntry" data-archive-item-id="{{this.id}}"
                                title="{{localize 'DSHIDEOUT.Archives.Remove'}}">
                          <i class="fas fa-trash"></i>
                        </button>
                      {{/if}}
                      <i class="fas fa-chevron-down dshideout-stash-expand-icon"
                         data-action="toggleDescription"
                         data-description-id="{{this.id}}"
                         data-chevron-id="{{this.id}}"></i>
                    </div>
                  </div>
                  <div class="dshideout-collapsible {{#if this.isExpanded}}is-expanded{{/if}}"
                       data-collapsible-id="{{this.id}}"
                       data-action="toggleDescription"
                       data-description-id="{{this.id}}">
                    <div class="dshideout-collapsible-inner">
                      <div class="dshideout-stash-expanded">
                        {{#if this.keywords.length}}
                          <div class="dshideout-item-keywords-row">
                            {{#each this.keywords}}<span class="dshideout-char-pill">{{this}}</span>{{/each}}
                          </div>
                        {{/if}}
                        {{#if this.description}}{{{this.description}}}{{/if}}
                        {{#if this.projectData}}
                          <div class="dshideout-stash-project-meta">
                            {{#if this.projectData.goal}}<span><strong>Goal:</strong> {{this.projectData.goal}}</span>{{/if}}
                            {{#if this.projectData.prerequisites}}<span><strong>Prerequisites:</strong> {{this.projectData.prerequisites}}</span>{{/if}}
                            {{#if this.projectData.source}}<span><strong>Source Material:</strong> {{this.projectData.source}}</span>{{/if}}
                          </div>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/each}}
      {{else}}
        <div class="dshideout-empty-state">
          <i class="fas fa-book-open dshideout-empty-icon"></i>
          <p>{{localize "DSHIDEOUT.Archives.None"}}</p>
          {{#if isGM}}<p class="dshideout-empty-hint">{{localize "DSHIDEOUT.Archives.DropHint"}}</p>{{/if}}
        </div>
      {{/if}}
    </div>
  </div>
  {{/dshideout-eq}}

  {{!-- ==================  STASH TAB  ================== --}}
  {{#dshideout-eq activeTab "stash"}}
  <div class="dshideout-stash-panel {{#if isGM}}is-gm{{else}}is-player{{/if}}" data-stash-drop-zone>
    <hr class="dshideout-divider" />
    <div class="dshideout-stash-list">
      {{#if stashGroups.length}}
        {{#each stashGroups}}
          <section class="dshideout-stash-group">
            <div class="dshideout-stash-group-header">
              <span class="dshideout-group-icon-spacer"></span>
              <span class="dshideout-group-label">{{this.label}}</span>
              <span class="dshideout-col-header-text dshideout-stash-col-echelon">{{localize "DSHIDEOUT.Column.Echelon"}}</span>
              <span class="dshideout-col-header-text dshideout-stash-col-qty">{{localize "DSHIDEOUT.Column.Quantity"}}</span>
            </div>
            <ul class="dshideout-stash-items">
              {{#each this.items}}
                <li class="dshideout-stash-row {{#if this.isExpanded}}is-expanded{{/if}}"
                    data-stash-item-id="{{this.id}}"
                    draggable="true"
                    data-drag-stash-item>
                  <div class="dshideout-stash-row-header"
                       data-action="toggleDescription"
                       data-description-id="{{this.id}}">
                    <img class="dshideout-stash-icon" src="{{this.img}}" alt="{{this.name}}" />
                    <div class="dshideout-stash-info">
                      <span class="dshideout-stash-name">{{this.name}}</span>
                    </div>
                    <span class="dshideout-stash-col-echelon dshideout-col-value">{{this.echelonLabel}}</span>
                    <span class="dshideout-stash-col-qty dshideout-col-value">{{this.quantity}}</span>
                    <div class="dshideout-stash-row-btns">
                      {{#if @root.isGM}}
                        <button type="button" class="dshideout-qty-btn" data-action="decreaseQty" data-stash-item-id="{{this.id}}">−</button>
                        <button type="button" class="dshideout-qty-btn" data-action="increaseQty" data-stash-item-id="{{this.id}}">+</button>
                        <button type="button" class="dshideout-btn dshideout-btn-secondary dshideout-btn-icon"
                                data-action="openProjectSheet" data-uuid="{{this.uuid}}"
                                title="{{localize 'DSHIDEOUT.Common.OpenItemSheet'}}">
                          <i class="fas fa-book"></i>
                        </button>
                        <button type="button" class="dshideout-btn dshideout-btn-danger dshideout-btn-icon"
                                data-action="removeStashItem" data-stash-item-id="{{this.id}}"
                                title="{{localize 'DSHIDEOUT.Stash.Remove'}}">
                          <i class="fas fa-trash"></i>
                        </button>
                      {{/if}}
                    </div>
                    <i class="fas fa-chevron-down dshideout-stash-expand-icon"
                       data-action="toggleDescription"
                       data-description-id="{{this.id}}"
                       data-chevron-id="{{this.id}}"></i>
                  </div>
                  <div class="dshideout-collapsible {{#if this.isExpanded}}is-expanded{{/if}}"
                       data-collapsible-id="{{this.id}}"
                       data-action="toggleDescription"
                       data-description-id="{{this.id}}">
                    <div class="dshideout-collapsible-inner">
                      <div class="dshideout-stash-expanded">
                        {{#if this.keywords.length}}
                          <div class="dshideout-item-keywords-row">
                            {{#each this.keywords}}<span class="dshideout-char-pill">{{this}}</span>{{/each}}
                          </div>
                        {{/if}}
                        {{#if this.description}}{{{this.description}}}{{/if}}
                        {{#if this.projectData}}
                          <div class="dshideout-stash-project-meta">
                            {{#if this.projectData.goal}}<span><strong>Goal:</strong> {{this.projectData.goal}}</span>{{/if}}
                            {{#if this.projectData.prerequisites}}<span><strong>Prerequisites:</strong> {{this.projectData.prerequisites}}</span>{{/if}}
                            {{#if this.projectData.projectSource}}<span><strong>Source Material:</strong> {{this.projectData.projectSource}}</span>{{/if}}
                          </div>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                </li>
              {{/each}}
            </ul>
          </section>
        {{/each}}
      {{else}}
        <div class="dshideout-empty-state">
          <i class="fas fa-box-open dshideout-empty-icon"></i>
          <p>{{localize "DSHIDEOUT.Stash.None"}}</p>
        </div>
      {{/if}}

      {{!-- Drop zone hint scrolls with list (visible to anyone with permission) --}}
      <div class="dshideout-drop-hint">
        <i class="fas fa-plus-circle"></i> {{localize "DSHIDEOUT.Stash.DropHint"}}
      </div>
    </div>

  </div>
  {{/dshideout-eq}}

</div>
