{{!-- Project Browser --}}
<div class="dshideout-browser-panel">

  {{!-- Search + Filters --}}
  <div class="dshideout-browser-controls">
    <div class="dshideout-search-row">
      <i class="fas fa-search dshideout-search-icon"></i>
      <input type="text"
             class="dshideout-browser-search"
             placeholder="{{localize 'DSHIDEOUT.ProjectBrowser.SearchPlaceholder'}}"
             value="{{searchText}}" />
      {{#if searchText}}
        <button type="button" class="dshideout-clear-search" data-action="clearSearch" title="{{localize 'DSHIDEOUT.Browser.ClearSearch'}}">
          <i class="fas fa-times"></i>
        </button>
      {{/if}}
    </div>

      <div class="dshideout-filter-row">
      <select name="typeFilter" class="dshideout-select">
        {{#each typeOptions}}
          <option value="{{this.value}}" {{#dshideout-eq ../typeFilter this.value}}selected{{/dshideout-eq}}>{{this.label}}</option>
        {{/each}}
      </select>

      {{#if isGM}}
      <div class="dshideout-source-filter-row">
        <div class="dshideout-source-chips">
          {{#each sourceChips}}
            <span class="dshideout-source-chip">
              {{this.label}}
              <button type="button" class="dshideout-source-chip-x" data-action="removeSource" data-source="{{this.value}}">×</button>
            </span>
          {{/each}}
        </div>
        {{#if availableSources.length}}
          <select class="dshideout-select dshideout-small-select" name="addSource">
            <option value="">+ {{localize "DSHIDEOUT.Browser.Sources"}}</option>
            {{#each availableSources}}
              <option value="{{this.value}}">{{this.label}}</option>
            {{/each}}
          </select>
        {{/if}}
      </div>
      {{/if}}
    </div>
  </div>

  {{!-- Count --}}
  <div class="dshideout-browser-count">
    {{totalCount}} {{localize "DSHIDEOUT.Browser.Results"}}
  </div>
  <hr class="dshideout-divider" />

  {{!-- List --}}
  <ul class="dshideout-browser-list">
    {{#if isLoading}}
      <li class="dshideout-loading">
        <i class="fas fa-spinner fa-spin"></i> {{localize "DSHIDEOUT.Browser.Loading"}}
      </li>
    {{else if entries.length}}
      {{#each entries}}
        <li class="dshideout-browser-row {{#if this.isSelected}}is-selected{{/if}}" data-uuid="{{this.uuid}}">
          {{!-- Full top section is clickable to select / expand --}}
          <div class="dshideout-browser-row-top" data-action="selectRow" data-uuid="{{this.uuid}}">
            {{!-- Row 1: Icon + Name + Goal --}}
            <div class="dshideout-browser-row-header">
              <img class="dshideout-browser-icon" src="{{this.img}}" alt="{{this.name}}" />
              <div class="dshideout-browser-name-col">
                <span class="dshideout-browser-name">{{this.name}}</span>
                {{#if this.goal}}
                  <span class="dshideout-browser-goal">{{localize "DSHIDEOUT.ProjectBrowser.Goal"}}: {{this.goal}}</span>
                {{/if}}
              </div>
            </div>
            {{!-- Row 2+: Type and Rolls --}}
            <div class="dshideout-browser-meta-rows">
              <div class="dshideout-browser-meta-row">
                <span class="dshideout-meta-label">{{localize "DSHIDEOUT.Projects.TypeLabel"}}:</span>
                <span class="dshideout-type-label">{{this.typeLabel}}</span>
              </div>
              {{#if this.charLabels.length}}
              <div class="dshideout-browser-meta-row">
                <span class="dshideout-meta-label">{{localize "DSHIDEOUT.Projects.CharsLabel"}}:</span>
                {{#each this.charLabels}}
                  <span class="dshideout-char-pill">{{this}}</span>
                {{/each}}
              </div>
              {{/if}}
            </div>
          </div>

          <div class="dshideout-collapsible {{#if this.isSelected}}is-expanded{{/if}}" data-collapsible-id="browser-{{this.uuid}}">
            <div class="dshideout-collapsible-inner dshideout-browser-details">
              {{#if this.projectSource}}
                <p class="dshideout-browser-project-source"><strong>{{localize "DSHIDEOUT.Projects.ProjectSource"}}:</strong> {{this.projectSource}}</p>
              {{else}}
                <p class="dshideout-browser-source">{{localize "DSHIDEOUT.Browser.Source"}}: {{this.sourceLabel}}</p>
              {{/if}}
              {{#if this.prerequisites}}
                <p><strong>{{localize "DSHIDEOUT.Projects.Prerequisites"}}:</strong> {{this.prerequisites}}</p>
              {{/if}}
              <div class="dshideout-browser-description">{{{this.description}}}</div>
            </div>
          </div>
        </li>
      {{/each}}
    {{else}}
      <li class="dshideout-browser-empty">
        <i class="fas fa-search"></i>
        <p>{{localize "DSHIDEOUT.Browser.NoResults"}}</p>
      </li>
    {{/if}}
  </ul>

  {{!-- Footer bar: static action button for selected item --}}
  <div class="dshideout-browser-footer">
    {{#if selectedEntry}}
      <span class="dshideout-footer-item-name">{{selectedEntry.name}}</span>
      <input type="text" class="dshideout-detail-input"
             placeholder="{{localize 'DSHIDEOUT.ProjectBrowser.DetailPlaceholder'}}"
             value="" maxlength="80" />
      <button type="button" class="dshideout-btn dshideout-btn-primary"
              data-action="addSelectedProject">
        <i class="fas fa-plus"></i> {{localize "DSHIDEOUT.ProjectBrowser.AddProject"}}
      </button>
    {{else}}
      <span class="dshideout-footer-hint">{{localize "DSHIDEOUT.ProjectBrowser.SelectHint"}}</span>
    {{/if}}
  </div>

</div>
